# API and Worker Settings
ENVIRONMENT=development
LOG_LEVEL=info

# External Dependencies Connections
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openworkers

# ─── LLM Provider API Keys ──────────────────────────────────────
# Set keys for whichever providers you want available.
# You need at least ONE. The system falls back if a provider has no key.
#
# How it maps:
#   THESIS_*_PROVIDER=anthropic  ->  reads ANTHROPIC_API_KEY
#   THESIS_*_PROVIDER=openai     ->  reads OPENAI_API_KEY
#   THESIS_*_PROVIDER=deepseek   ->  reads DEEPSEEK_API_KEY
#
# Only set the keys you need. Others can stay empty.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── Per-Mode Provider + Model ──────────────────────────────────
# Three modes control which provider AND model each agent uses:
#   quality   - HEAD planner, HEAD supervisor, critic agent
#   balanced  - checker agent, synthesizer agent
#   cheap     - researcher agent
#
# REQUIRED: Pick ONE section below, uncomment it, and replace the model
# names with the ones you want. The system will NOT auto-select — you
# must configure this explicitly. Set model names to whatever your
# provider supports
#
# If the provider has no API key set, the system errors at startup.

# ▼ Single Anthropic ▼
#THESIS_QUALITY_PROVIDER=anthropic
#THESIS_QUALITY_MODEL=name-of-strong-model-here
#THESIS_BALANCED_PROVIDER=anthropic
#THESIS_BALANCED_MODEL=name-of-mid-model-here
#THESIS_CHEAP_PROVIDER=anthropic
#THESIS_CHEAP_MODEL=name-of-cheap-model-here

# ▼ Single OpenAI ▼
#THESIS_QUALITY_PROVIDER=openai
#THESIS_QUALITY_MODEL=name-of-strong-model-here
#THESIS_BALANCED_PROVIDER=openai
#THESIS_BALANCED_MODEL=name-of-mid-model-here
#THESIS_CHEAP_PROVIDER=openai
#THESIS_CHEAP_MODEL=name-of-cheap-model-here

# ▼ Single DeepSeek ▼
#THESIS_QUALITY_PROVIDER=deepseek
#THESIS_QUALITY_MODEL=name-of-strong-model-here
#THESIS_BALANCED_PROVIDER=deepseek
#THESIS_BALANCED_MODEL=name-of-mid-model-here
#THESIS_CHEAP_PROVIDER=deepseek
#THESIS_CHEAP_MODEL=name-of-cheap-model-here

# ▼ Mixed (edit provider names + model names per mode) ▼
#THESIS_QUALITY_PROVIDER=name-of-provider-here
#THESIS_QUALITY_MODEL=name-of-strong-model-here
#THESIS_BALANCED_PROVIDER=name-of-provider-here
#THESIS_BALANCED_MODEL=name-of-mid-model-here
#THESIS_CHEAP_PROVIDER=name-of-provider-here
#THESIS_CHEAP_MODEL=name-of-cheap-model-here

# ─── Runtime ────────────────────────────────────────────────────
DRY_RUN=false
