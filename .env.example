# API and Worker Settings
ENVIRONMENT=development
LOG_LEVEL=info

# External Dependencies Connections
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openworkers

# Secrets for Agent Providers
# HEAD Tier (Trusted, Highest Quality Policy & Planner)
# Intended for Claude opus or latest version of gpt max
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MID Tier (Western, Reliable & Fast)
# Intended for dedupe/clustering using GPT mini or Claude Haiku
OPENAI_API_KEY=your_openai_api_key_here

# WORKER Tier (Cheap, High Volume)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# Execution Toggles
DRY_RUN=false
